      _compat.$argument: 'url1={{{订阅链接1}}}&title1={{{订阅名称1}}}&url2={{{订阅链接2}}}&title2={{{订阅名称2}}}&url3={{{订阅链接3}}}&title3={{{订阅名称3}}}'

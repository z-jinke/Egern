#!name=Youtube
#!desc=修改布局屏蔽广告
#!arguments=屏蔽上传:true 屏蔽Shorts:true 字幕翻译:zh-Hans

rules:
- and:
    match:
    - domain_keyword:
        match: google
    - protocol:
        match: QUIC
    policy: REJECT

map_locals:
- match: ^https:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad
  status_code: 502
  body: ''

scriptings:
- http_response:
    name: 修改响应
    match: ^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$
    script_url: https://raw.githubusercontent.com/Maasea/sgmodule/master/Script/Youtube/youtube.response.js
    arguments:
      _compat.$argument: '{"lyricLang":"{{{歌词翻译语言}}}","captionLang":"{{{字幕翻译}}}","blockUpload":{{{屏蔽上传}}},"blockImmersive":{{{屏蔽选段按钮}}},"blockShorts":{{{屏蔽Shorts}}},"debug":{{{启用调试模式}}}}'
    body_required: true
    binary_body: true

mitm:
  hostnames:
    includes:
    - '*.googlevideo.com'
    - youtubei.googleapis.com

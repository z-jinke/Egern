name: 机场信息

compat_arguments:
  订阅链接: '订阅URL'
  机场名称: 填入
  重置日期: '1'
  图标: URL
  颜色: '#DF4688'

scriptings:
- generic:
    name: 订阅处理
    script_url: https://raw.githubusercontent.com/cc63/Surge/main/Module/Panel/Sub-info/Moore/Sub-info.js
    arguments:
      _compat.$argument: 'url={{{订阅链接}}}&title={{{机场名称}}}&reset_day={{{重置日期}}}&icon={{{图标}}}&color={{{颜色}}}'
    update_interval: 86400
    timeout: 5

panels:
- name: 订阅处理
  title: '机场信息'
  content: |
    名称：{{airport_name}}
    流量：{{used}} / {{total}}
    剩余：{{expire_day}} 天

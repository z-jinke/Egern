name: 机场流量信息

compat_arguments:
  订阅链接: '订阅URL'
  机场名称: 机场
  重置日期: '1'
  显示图标: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Area.png

scriptings:
- generic:
    name: 订阅处理
    script_url: https://raw.githubusercontent.com/cc63/Surge/main/Module/Panel/Sub-info/Moore/Sub-info.js
    arguments:
      _compat.$argument: 'url={{{订阅链接}}}&title={{{机场名称}}}&reset_day={{{重置日期}}}&icon={{{显示图标}}}'
    update_interval: 86400
    timeout: 10

panels:
- name: 订阅处理
  title: '机场信息'
  content: |
    名称：{{airport_name}}
    流量：{{used}} / {{total}}
    剩余：{{expire_day}} 天
